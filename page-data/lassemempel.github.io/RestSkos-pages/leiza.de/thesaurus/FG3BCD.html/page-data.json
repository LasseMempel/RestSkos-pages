{"componentChunkName":"component---src-components-concept-jsx","path":"/lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus/FG3BCD.html","result":{"pageContext":{"node":{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus/FG3BCD","type":"Concept","prefLabel":{"de":"Eichenholz"},"altLabel":{"de":["Quercus species"]},"hiddenLabel":null,"definition":{"de":"Holz aus Eichenbäumen. Das Holz der verschiedenen Eichenbäumen ist im allgemeinen als starkes und strapazierfähiges Holz zu beschreiben, welches eine üblicherweise hellbraune bis gelblich-braun/rötliche Färbung aufweist. Die Maserung verläuft häufig in markanten, wellenförmigen/gespiegelten Formen. Die mechanische Bearbeitbarkeit hängt im Detail von der jeweiligen Eichenart ab, ist insgesamt jedoch als gut zu beschreiben. "},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["FG3BCD"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus/D39191","prefLabel":{"de":"ringporiges Laubholz"}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":[{"id":"http://vocab.getty.edu/page/aat/300012264"},{"id":"https://cameo.mfa.org/wiki/Oak"}],"exactMatch":null,"inScheme":[{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus","title":null}],"inSchemeAll":[{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":""}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}