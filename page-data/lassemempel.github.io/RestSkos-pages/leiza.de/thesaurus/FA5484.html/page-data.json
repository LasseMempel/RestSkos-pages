{"componentChunkName":"component---src-components-concept-jsx","path":"/lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus/FA5484.html","result":{"pageContext":{"node":{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus/FA5484","type":"Concept","prefLabel":{"de":"Amphibol"},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Gruppe von Eisen-Magnesium-Silikatmineralen mit mittlerer Härte. Die Färbung ist meit dunkel, von grün bis schwarzer Farbe. Die Färbung hängt dabei vor allem vom Eisen-Gehalt der Mineralie ab. Die Spaltflächen der Amphibole zeigen sich oft mit einem Glas- oder Perlmuttglanz, während die nadeligen, faserartigen Formen von einem seidigen Glanz sind. Amphibole kommen in vielen magmatischen und metamorphosen Gesteinen vor, wie z. B in Graniten, Dioriten und vor allem in den Amphiobioliten."},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["FA5484"],"example":null,"narrower":[{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus/A43C59","prefLabel":{"de":"Hornblende"}}],"narrowerTransitive":[],"broader":{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus/BGC9F3","prefLabel":{"de":"Mineral"}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus","title":null}],"inSchemeAll":[{"id":"https://lassemempel.github.io/RestSkos-pages/leiza.de/thesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":""}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}