{"componentChunkName":"component---src-components-concept-jsx","path":"/thesaurus/FBA99A.html","result":{"pageContext":{"node":{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/FBA99A","type":"Concept","prefLabel":{"de":"instabil"},"altLabel":null,"hiddenLabel":null,"definition":{"de":"mangelnde Fähigkeit des Objektes in einem stabilem Zustand zu bleiben. Das Objekt droht durch physische Faktoren, wie äußere Kräfte oder unzureichende Unterstützung seine Form oder Struktur zu verändern/verlieren. Es bedarf demnach entsprechende Stabilisierungsmaßnahmen, um in seiner ursprünglichen Form zu bleiben. Die Instabilität seines Objektes liegt häufig in der Fragilität bzw. mangelnden Festigkeit seines Werkstoffes begründet. "},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["FBA99A"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/FB6AGB","prefLabel":{"de":"Stabilität"}},"broaderTransitive":null,"related":[{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/DG7A1D","prefLabel":{"de":"fragil"}}],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus","title":null}],"inSchemeAll":[{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://lassemempel.github.io/RestSkos-pages/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}