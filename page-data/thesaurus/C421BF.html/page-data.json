{"componentChunkName":"component---src-components-concept-jsx","path":"/thesaurus/C421BF.html","result":{"pageContext":{"node":{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/C421BF","type":"Concept","prefLabel":{"de":"Lösungsmittel"},"altLabel":{"de":["Lösemittel"]},"hiddenLabel":null,"definition":{"de":"Substanz, die in der Lage ist andere Stoffe (Feststoffe, Flüssigkeiten oder Gase) zu lösen, ohne dabei selbst eine chemische Reaktion mit diesem Stoff einzugehen. Das Lösungsmittel bildet eine homogene Mischung (Lösung) mit dem gelösten Stoff, in der die Moleküle des gelösten Stoffes in der Matrix des Lösemittels fein verteilt sind. "},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["C421BF"],"example":null,"narrower":[{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/AFC696","prefLabel":{"de":"Methyl-Ethyl-Keton"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/DFD1B7","prefLabel":{"de":"Wasser"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/B77A8F","prefLabel":{"de":"Ethylacetat"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/BBA28A","prefLabel":{"de":"Ethanol"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/BDG3D5","prefLabel":{"de":"Xylol"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/D347D6","prefLabel":{"de":"Terpentin"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/D627B2","prefLabel":{"de":"Toloul"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/D72F3A","prefLabel":{"de":"Aceton"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/G34563","prefLabel":{"de":"Testbenzin"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/G46243","prefLabel":{"de":"Propylacetat"}},{"id":"https://lassemempel.github.io/RestSkos-pages/thesaurus/GGD87G","prefLabel":{"de":"Coloradol"}}],"narrowerTransitive":[],"broader":{"id":"https://lassemempel.github.io/RestSkos-pa